    <worksheet name='Jinesh - Linear Regression via Tabpy.'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#c2c0b6' fontname='Anthropic Sans,-apple-system,BlinkMacSystemFont,Segoe UI,sans-serif' fontsize='18'>Linear Regression via Tabpy</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='cleaned_dataset (cleaned_dataset_Europa_global)' name='federated.0mk0h0s18oe37v17i3vez07tqkuy' />
          </datasources>
          <datasource-dependencies datasource='federated.0mk0h0s18oe37v17i3vez07tqkuy'>
            <column caption='Receiver Country Clean' datatype='string' name='[Calculation_1866208928993280]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF CONTAINS([receiver_country], &quot;;&quot;) THEN&#13;&#10;    SPLIT([receiver_country], &quot;;&quot;, 1)&#13;&#10;ELSE&#13;&#10;    [receiver_country]&#13;&#10;END' />
            </column>
            <column caption='Incident Count per Year' datatype='integer' name='[Calculation_1866210305056791]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED YEAR([start_date]) : COUNT([incident_id]) }' />
            </column>
            <column caption='Linear Regression Predicted' datatype='real' name='[Calculation_1866210306007065]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SCRIPT_REAL(&quot;&#13;&#10;import numpy as np&#13;&#10;import pandas as pd&#13;&#10;from sklearn.linear_model import LinearRegression&#13;&#10;&#13;&#10;x = pd.Series(_arg1).fillna(0).values.reshape(-1,1)&#13;&#10;y = pd.Series(_arg2).fillna(0).values&#13;&#10;&#13;&#10;model = LinearRegression()&#13;&#10;model.fit(x, y)&#13;&#10;&#13;&#10;return model.predict(x).tolist()&#13;&#10;&quot;,&#13;&#10;SUM([Calculation_1866210305056791]),&#13;&#10;AVG([impact_indicator_score])&#13;&#10;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column-instance column='[impact_indicator_score]' derivation='Avg' name='[avg:impact_indicator_score:qk]' pivot='key' type='quantitative' />
            <column caption='Impact Indicator Score' datatype='real' name='[impact_indicator_score]' role='dimension' type='ordinal' />
            <column caption='Incident Id' datatype='integer' name='[incident_id]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1866210305056791]' derivation='None' name='[none:Calculation_1866210305056791:qk]' pivot='key' type='quantitative' />
            <column caption='Receiver Country' datatype='string' name='[receiver_country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Start Date' datatype='date' name='[start_date]' role='dimension' type='ordinal' />
            <column-instance column='[Calculation_1866210306007065]' derivation='User' name='[usr:Calculation_1866210306007065:qk]' pivot='key' type='quantitative'>
              <table-calc ordering-type='Rows' />
            </column-instance>
            <column-instance column='[start_date]' derivation='Year' name='[yr:start_date:ok]' pivot='key' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0mk0h0s18oe37v17i3vez07tqkuy].[Action (Receiver Country Clean)]'>
            <groupfilter function='member' level='[Calculation_1866208928993280]' member='&quot;United States&quot;' user:ui-action-filter='[Action2_FD277C1F79714B658C186E1E2B657951]' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />

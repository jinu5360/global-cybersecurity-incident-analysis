      <aliases enabled='yes' />
      <column caption='Receiver Country Clean' datatype='string' name='[Calculation_1866208928993280]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([receiver_country], &quot;;&quot;) THEN&#13;&#10;    SPLIT([receiver_country], &quot;;&quot;, 1)&#13;&#10;ELSE&#13;&#10;    [receiver_country]&#13;&#10;END' />
      </column>
      <column caption='Attack Category' datatype='string' name='[Calculation_1866208930787329]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([incident_type]), &quot;data&quot;) THEN &quot;Data Theft&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([incident_type]), &quot;dox&quot;) THEN &quot;Doxing&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([incident_type]), &quot;disrupt&quot;) THEN &quot;Disruption&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([incident_type]), &quot;hijack&quot;) THEN &quot;Hijacking&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([incident_type]), &quot;ransom&quot;) THEN &quot;Ransomware&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Severity Risk Level' datatype='string' datatype-customized='true' name='[Calculation_1866210140741650]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([impact_indicator_score]) &gt;= 7 THEN &quot;Critical&quot;&#13;&#10;ELSEIF AVG([impact_indicator_score]) &gt;= 4 THEN &quot;High&quot;&#13;&#10;ELSEIF AVG([impact_indicator_score]) &gt;= 1 THEN &quot;Medium&quot;&#13;&#10;ELSE &quot;Low&quot;&#13;&#10;END' />
      </column>
      <column caption='Year Filter' datatype='boolean' name='[Calculation_1866210145644563]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='YEAR([start_date]) &gt;= [Parameters].[Parameter 1]' />
      </column>
      <column caption='Incident Count per Year' datatype='integer' name='[Calculation_1866210305056791]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED YEAR([start_date]) : COUNT([incident_id]) }' />
      </column>
      <column caption='Linear Regression Predicted' datatype='real' name='[Calculation_1866210306007065]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SCRIPT_REAL(&quot;&#13;&#10;import numpy as np&#13;&#10;import pandas as pd&#13;&#10;from sklearn.linear_model import LinearRegression&#13;&#10;&#13;&#10;x = pd.Series(_arg1).fillna(0).values.reshape(-1,1)&#13;&#10;y = pd.Series(_arg2).fillna(0).values&#13;&#10;&#13;&#10;model = LinearRegression()&#13;&#10;model.fit(x, y)&#13;&#10;&#13;&#10;return model.predict(x).tolist()&#13;&#10;&quot;,&#13;&#10;SUM([Calculation_1866210305056791]),&#13;&#10;AVG([impact_indicator_score])&#13;&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='cleaned_dataset' datatype='table' name='[__tableau_internal_object_id__].[cleaned!dataset_3D5266447CBD43FBA77EB88756DDF46B]' role='measure' type='quantitative' />
